OLLAMA_BASE_URL=http://localhost:11434

# Stage 1 — clinical reasoning (MedGemma, medically trained)
MEDGEMMA_MODEL=medgemma:4b

# Stage 2 — JSON formatting (swap freely based on available hardware)
# Fast, low RAM (recommended for laptop):  gemma4:e4b
# High quality (needs ~18GB+ RAM):         gemma3:27b
GEMMA_MODEL=gemma4:e4b

DATABASE_URL=sqlite+aiosqlite:///./gemma.db

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

APP_HOST=0.0.0.0
APP_PORT=8000
